# Pilot App - exemplo de variáveis de ambiente
# Copie para .env e ajuste: cp .env.example .env

# local = backend na sua máquina
# dev / staging / prod = ambientes remotos
ENV=local

# URL base da API (sem barra no final)
# Padrão: Android Studio / emulador Android (10.0.2.2 = host). Para iOS ou Chrome: use http://localhost:8080
BASE_URL=http://10.0.2.2:8080

# Quando true, usa mocks (login, rotas, etc.) em vez da API real
# isMockEnabled=false

# Certificate pinning (produção): defina true e CERT_PIN_SHA256 (hash SHA-256 em hex do certificado)
# ENABLE_CERTIFICATE_PINNING=false
# CERT_PIN_SHA256=
